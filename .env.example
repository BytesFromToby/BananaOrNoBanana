# Banana or No Banana — player seat config (copy to .env; .env is gitignored).
#
# Each seat is independently configured. TYPE is "human" (played in the browser)
# or "ai" (driven by an LLM). Providers: ollama | openai_compat | anthropic.
#   - ollama:        BASE_URL like http://127.0.0.1:11434 (no /v1). No API key needed.
#   - openai_compat: BASE_URL must include the version path, e.g.
#                    https://api.openai.com/v1, or a local/OpenRouter/vLLM endpoint.
#   - anthropic:     BASE_URL optional, defaults to https://api.anthropic.com.

# LeftPlayer — the Box Holder. Knows the truth, bluffs. Default: local Ollama.
LEFT_PLAYER_TYPE=ai
LEFT_PLAYER_PROVIDER=ollama
LEFT_PLAYER_MODEL=qwen3:8b
LEFT_PLAYER_BASE_URL=http://127.0.0.1:11434
LEFT_PLAYER_API_KEY=

# RightPlayer — the Guesser. Default: human, played in the browser.
# Set TYPE=ai to have an LLM play the Guesser (auto-play mode).
RIGHT_PLAYER_TYPE=human
RIGHT_PLAYER_PROVIDER=
RIGHT_PLAYER_MODEL=
RIGHT_PLAYER_BASE_URL=
RIGHT_PLAYER_API_KEY=
