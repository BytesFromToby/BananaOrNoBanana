# Banana or No Banana — player seat config (copy to .env; .env is gitignored).
#
# Each player is a persistent color identity — Red and Blue. The ROLE (Box Holder
# vs Guesser) is assigned per game, not welded to the color, so these blocks
# configure only the player identity (human/AI + provider/model), not a role.
# TYPE is "human" (played in the browser) or "ai" (driven by an LLM).
# Providers: ollama | openai_compat | anthropic.
#   - ollama:        BASE_URL like http://127.0.0.1:11434 (no /v1). No API key needed.
#   - openai_compat: BASE_URL must include the version path, e.g.
#                    https://api.openai.com/v1, or a local/OpenRouter/vLLM endpoint.
#   - anthropic:     BASE_URL optional, defaults to https://api.anthropic.com.

# RedPlayer — a player identity, role assigned per game. Default: local Ollama.
RED_PLAYER_TYPE=ai
RED_PLAYER_PROVIDER=ollama
RED_PLAYER_MODEL=qwen3:8b
RED_PLAYER_BASE_URL=http://127.0.0.1:11434
RED_PLAYER_API_KEY=

# BluePlayer — a player identity, role assigned per game. Default: human.
# Set TYPE=ai to have an LLM play this color (AI-vs-AI rotation).
BLUE_PLAYER_TYPE=human
BLUE_PLAYER_PROVIDER=
BLUE_PLAYER_MODEL=
BLUE_PLAYER_BASE_URL=
BLUE_PLAYER_API_KEY=

# HUMAN_ROLE — which role the human takes when one seat is human: guesser|holder
# (default guesser). Ignored in AI-vs-AI games (roles rotate automatically).
#HUMAN_ROLE=guesser
